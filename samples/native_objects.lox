// Native object test — StringList wrapper

var list = StringList();
list.add("hello");
list.add("world");
list.add("foo");

print list.count();    // expect: 3
print list.get(0);     // expect: hello
print list.get(1);     // expect: world

list.remove(0);
print list.get(0);     // expect: world
print list.count();    // expect: 2

print list;            // expect: <StringList>

print "Native object test passed.";
