// Test: simulated mouse drives the poll natives — mouseClicked is a
// one-frame edge, mouseDown tracks held state, mouseX/mouseY follow
// the simulated position.
var frame = 0;

onFrame(fun(dt) {
  frame = frame + 1;

  if (frame == 1) {
    simulateMouseDown(0, 50, 60);
  }
  if (frame == 2) {
    if (mouseClicked(0)) print "clicked";            // expect: clicked
    if (mouseDown(0)) print "down";                  // expect: down
    if (mouseX() == 50) print "x";                   // expect: x
    if (mouseY() == 60) print "y";                   // expect: y
  }
  if (frame == 3) {
    if (!mouseClicked(0)) print "edge once";         // expect: edge once
    if (mouseDown(0)) print "still down";            // expect: still down
    simulateMouseUp(0, 55, 65);
  }
  if (frame == 4) {
    if (!mouseDown(0)) print "released";             // expect: released
    if (mouseX() == 55) print "x moved";             // expect: x moved
    if (mouseY() == 65) print "y moved";             // expect: y moved
    // Other buttons untouched throughout.
    if (!mouseDown(1)) print "btn1 idle";            // expect: btn1 idle
    stopGameLoop();
  }
});

runGameLoop(0);
print "done";                                        // expect: done
