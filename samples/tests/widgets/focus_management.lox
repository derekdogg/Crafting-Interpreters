// Test: keyboard focus — click-to-focus on an edit, a press on a
// non-focusable widget or empty canvas clears focus, focusWidget sets
// it explicitly, disabling the focused widget drops it.
var e = createEdit(10, 10, 80, 20);
var b = createButton(10, 50, 80, 20, "B");
var frame = 0;

onFrame(fun(dt) {
  frame = frame + 1;
  updateWidgets();

  if (frame == 1) {
    if (focusedWidget() == 0) print "starts blurred";  // expect: starts blurred
    simulateMouseDown(0, 50, 20);
    simulateMouseUp(0, 50, 20);
  }
  if (frame == 2) {
    if (focusedWidget() == e) print "click focuses";   // expect: click focuses
    simulateMouseDown(0, 50, 60);
    simulateMouseUp(0, 50, 60);
  }
  if (frame == 3) {
    if (focusedWidget() == 0) print "button clears";   // expect: button clears
    focusWidget(e);
    if (focusedWidget() == e) print "explicit";        // expect: explicit
    simulateMouseDown(0, 250, 200);
    simulateMouseUp(0, 250, 200);
  }
  if (frame == 4) {
    if (focusedWidget() == 0) print "canvas clears";   // expect: canvas clears
    focusWidget(e);
    setWidgetEnabled(e, false);
    if (focusedWidget() == 0) print "disable clears";  // expect: disable clears
    setWidgetEnabled(e, true);
    // focusWidget refuses non-focusable and unknown targets.
    focusWidget(b);
    if (focusedWidget() == 0) print "button refused";  // expect: button refused
    focusWidget(9999);
    if (focusedWidget() == 0) print "stale refused";   // expect: stale refused
    stopGameLoop();
  }
});

runGameLoop(0);
print "done";                                          // expect: done
