// Test: edit-box editing keys via simulateKeyDown — backspace deletes
// before the caret, home/end/left/right move it, delete removes after
// it. simulateKeyDown synthesizes the WM_CHAR for char-producing keys
// (backspace) and the nav edge for the others, like real hardware.
var e = createEdit(10, 10, 100, 20, "abcd");
var frame = 0;

onFrame(fun(dt) {
  frame = frame + 1;
  updateWidgets();

  if (frame == 1) {
    focusWidget(e);   // caret starts after the initial text
    simulateKeyDown("backspace");
    simulateKeyUp("backspace");
  }
  if (frame == 2) {
    if (getEditText(e) == "abc") print "backspace";  // expect: backspace
    simulateKeyDown("home");
    simulateKeyUp("home");
  }
  if (frame == 3) {
    simulateKeyDown("delete");
    simulateKeyUp("delete");
  }
  if (frame == 4) {
    if (getEditText(e) == "bc") print "delete";      // expect: delete
    simulateKeyDown("right");
    simulateKeyUp("right");
  }
  if (frame == 5) {
    simulateChars("X");   // caret between b and c
  }
  if (frame == 6) {
    if (getEditText(e) == "bXc") print "insert mid"; // expect: insert mid
    simulateKeyDown("end");
    simulateKeyUp("end");
  }
  if (frame == 7) {
    simulateChars("Z");
  }
  if (frame == 8) {
    if (getEditText(e) == "bXcZ") print "end";       // expect: end
    stopGameLoop();
  }
});

runGameLoop(0);
print "done";                                        // expect: done
