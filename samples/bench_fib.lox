fun fib(n) {
  if (n < 2) return n;
  return fib(n - 1) + fib(n - 2);
}

var start = clock();
var result = fib(40);
var elapsed = clock() - start;

print elapsed;

print "fib(40) = " + str(result);
print "elapsed: " + str(elapsed) + "s";

