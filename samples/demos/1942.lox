// ============================================================
// 1942 — a simple arcade tribute
// ============================================================
// A vertically-scrolling shoot-'em-up in the spirit of Capcom's 1942:
// your fighter climbs an endless ocean, enemy planes fly in from the
// top in weaving, sweeping, or diving patterns, and colliding with one
// (or its friends) costs a life just like ramming did in the original.
// The signature move survives too: press Z to pull a barrel ROLL — a
// few seconds of invulnerability, in limited supply, replenished every
// time you clear a stage.
//
// Controls: ARROWS/WASD fly (4 directions), SPACE fire (hold),
//           Z barrel roll (dodge), ENTER start/restart, ESC quit.
// ============================================================

setCanvasSize(384, 600);

var w = canvasWidth();
var h = canvasHeight();

var SPR = 2;   // sprite scale, same convention as galaga.lox
var BOSS_SPR = 5;   // boss is drawn noticeably bigger than regular sprites

// ------------------------------------------------------------
// Helpers
// ------------------------------------------------------------
fun fmod(a, b) {
  return a - floor(a / b) * b;
}

fun rectsOverlap(ax, ay, aw, ah, bx, by, bw, bh) {
  if (ax + aw <= bx) return false;
  if (bx + bw <= ax) return false;
  if (ay + ah <= by) return false;
  if (by + bh <= ay) return false;
  return true;
}

