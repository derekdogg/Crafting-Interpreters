  "MMLLMMMMDMMMLMMM" +
  "MMMMMMMDDMMMMMMM" +
  "MMMMMMMDMMMMMMMM" +
  "MDDMMMMMMMMLLMMM" +
  "MMDDMMMMMMMMMMMM" +
  "MMMDMMMMMDDMMMMM" +
  "MMMMMMMMMMDDMMMM" +
  "MLLMMMMMMMMDMMMM" +
  "MMLMMMDDMMMMMMMM" +
  "MMMMMMMDDMMMMMMM" +
  "MMMMMMMMMMMMLLMM" +
  "MDMMMMMMMMMMMMMM" +
  "MMDMMMMLLMMMMMMM" +
  "MMMMMMMMMMMMMMMM"
);

