// ============================================================
// CRYSTAL CAVERNS — engine showcase platformer
//
// Exercises the parts of the engine no other demo touches:
//   * createTilemap/setTile/getTile/drawTilemap  — the level
//   * setCamera            — smooth-follow scrolling (world + HUD reset)
//   * createSurface/setRenderTarget/drawSurface  — pre-rendered parallax
//   * setClipRect          — world viewport under the HUD strip
//   * drawSpriteRotated    — spinning crystals
//   * flipSprite           — left/right facing player + slimes
//   * playTone/Sweep/Noise/Sequence — SFX + looping music
//   * onFrame/runGameLoop/stopGameLoop + onKeyPressed/onKeyReleased
//
// Collect every crystal, then reach the door. Arrows/WASD to move,
// SPACE to jump (release early for a short hop), ESC quits.
// ============================================================

var TILE = 16;
var VIEW_W = 480;
var VIEW_H = 240;   // world viewport height (15 tile rows)
var HUD_H = 16;     // HUD strip above the world

setCanvasSize(VIEW_W, VIEW_H + HUD_H);

var COLS = 100;
var ROWS = 15;
var WORLD_W = COLS * TILE;

// ------------------------------------------------------------
// Helpers
// ------------------------------------------------------------
fun fmod(a, b) {
  return a - floor(a / b) * b;
}

fun rectsOverlap(ax, ay, aw, ah, bx, by, bw, bh) {
  if (ax + aw <= bx) return false;
  if (bx + bw <= ax) return false;
  if (ay + ah <= by) return false;
  if (by + bh <= ay) return false;
  return true;
}

// ------------------------------------------------------------
// Sprites
// ------------------------------------------------------------

// Cave rock (solid)
setPaletteColor("M", 66, 74, 94);
setPaletteColor("D", 44, 48, 62);
setPaletteColor("L", 92, 102, 128);
