var doorArt = "FFFFFFFFFFFFFFFF";
var dr = 1;
while (dr <= 22) {
  if (dr == 12) {
    doorArt = doorArt + "FWWWWWWWDWWWYWWF";
  } else {
    doorArt = doorArt + doorRow;
  }
  dr = dr + 1;
}
doorArt = doorArt + "FFFFFFFFFFFFFFFF";
var sprDoorClosed = createPaletteSprite(16, 24, doorArt);

setPaletteColor("K", 8, 8, 16);
var openRow = "FKKKKKKKKKKKKKKF";
doorArt = "FFFFFFFFFFFFFFFF";
dr = 1;
while (dr <= 22) {
  if (dr == 7) {
    doorArt = doorArt + "FKKKKYKKKKKKKKKF";
  } else if (dr == 15) {
    doorArt = doorArt + "FKKKKKKKKKKYKKKF";
  } else {
    doorArt = doorArt + openRow;
  }
  dr = dr + 1;
}
doorArt = doorArt + "FFFFFFFFFFFFFFFF";
var sprDoorOpen = createPaletteSprite(16, 24, doorArt);

// HUD heart
