// GC edge-case tests targeting gaps in existing coverage.
// Each section exercises a specific allocation pattern known to be GC-sensitive.

// =========================================================================
// TEST 1: 64+ globals defined back-to-back
// Forces the globals hash table to resize during OP_DEFINE_GLOBAL.
// If GC fires mid-resize, the half-populated table could lose entries.
// =========================================================================

var g00 = "v00"; var g01 = "v01"; var g02 = "v02"; var g03 = "v03";
var g04 = "v04"; var g05 = "v05"; var g06 = "v06"; var g07 = "v07";
var g08 = "v08"; var g09 = "v09"; var g10 = "v10"; var g11 = "v11";
var g12 = "v12"; var g13 = "v13"; var g14 = "v14"; var g15 = "v15";
var g16 = "v16"; var g17 = "v17"; var g18 = "v18"; var g19 = "v19";
var g20 = "v20"; var g21 = "v21"; var g22 = "v22"; var g23 = "v23";
var g24 = "v24"; var g25 = "v25"; var g26 = "v26"; var g27 = "v27";
var g28 = "v28"; var g29 = "v29"; var g30 = "v30"; var g31 = "v31";
var g32 = "v32"; var g33 = "v33"; var g34 = "v34"; var g35 = "v35";
var g36 = "v36"; var g37 = "v37"; var g38 = "v38"; var g39 = "v39";
var g40 = "v40"; var g41 = "v41"; var g42 = "v42"; var g43 = "v43";
var g44 = "v44"; var g45 = "v45"; var g46 = "v46"; var g47 = "v47";
var g48 = "v48"; var g49 = "v49"; var g50 = "v50"; var g51 = "v51";
var g52 = "v52"; var g53 = "v53"; var g54 = "v54"; var g55 = "v55";
var g56 = "v56"; var g57 = "v57"; var g58 = "v58"; var g59 = "v59";
var g60 = "v60"; var g61 = "v61"; var g62 = "v62"; var g63 = "v63";
var g64 = "v64"; var g65 = "v65"; var g66 = "v66"; var g67 = "v67";
var g68 = "v68"; var g69 = "v69"; var g70 = "v70"; var g71 = "v71";

collectGarbage();

// Spot-check that values survived
assert(g00 == "v00");
assert(g35 == "v35");
assert(g63 == "v63");
assert(g71 == "v71");

// =========================================================================
// TEST 2: OP_CLOSE_UPVALUE where closed value is an array
// The upvalue's `closed` field becomes the sole root for the collection.
// If BlackenObject doesn't trace ObjUpvalue → closed → array elements,
// the array's contents get collected.
// =========================================================================

fun closeArray() {
  var arr = newArray();
  arrayPush(arr, "survive1");
  arrayPush(arr, "survive2");
  arrayPush(arr, "survive3");
  fun getter() { return arr; }
  return getter;
}
var getArr = closeArray();
// arr is now only reachable via closed upvalue
collectGarbage();
collectGarbage();
var closedArr = getArr();
assert(arrayLen(closedArr) == 3);
assert(arrayGet(closedArr, 0) == "survive1");
assert(arrayGet(closedArr, 2) == "survive3");

// =========================================================================
// TEST 3: OP_CLOSE_UPVALUE where closed value is a dictionary
// =========================================================================

fun closeDict() {
  var d = dictNew();
  dictSet(d, "key1", "val1");
  dictSet(d, "key2", "val2");
  fun getter() { return d; }
  return getter;
}
var getDict = closeDict();
collectGarbage();
collectGarbage();
var closedDict = getDict();
assert(dictGet(closedDict, "key1") == "val1");
assert(dictGet(closedDict, "key2") == "val2");

// =========================================================================
// TEST 4: Array/dict passed as function argument while other args allocate
// The array sits on the stack during call setup. If evaluating subsequent
// arguments triggers GC, the array must remain rooted via the stack.
// =========================================================================

fun takeBoth(collection, str) {
  arrayPush(collection, str);
  return collection;
}

var argArr = newArray();
// "heavy" + "alloc" creates a new string — may trigger GC — while argArr is already on stack
var result = takeBoth(argArr, "heavy" + "alloc" + "string" + "concat");
assert(arrayGet(result, 0) == "heavyallocstringconcat");

// More aggressive: multiple allocating args
fun take3(a, b, c) { return a + b + c; }
var r = take3("x" + "1", "y" + "2", "z" + "3");
assert(r == "x1y2z3");

// Dict as argument with allocating second arg
fun dictAndStr(d, s) { dictSet(d, "k", s); return d; }
var argDict = dictNew();
var rd = dictAndStr(argDict, "alloc" + "value");
assert(dictGet(rd, "k") == "allocvalue");

// =========================================================================
// TEST 5: Record constructor with allocating field expressions
// First field value is on the stack while second field allocates.
// =========================================================================

record Pair(first, second);
record Triple(a, b, c);

// Concat in field expressions
var p = Pair("hello" + "world", "foo" + "bar");
assert(p.first == "helloworld");
assert(p.second == "foobar");

// Multiple allocating fields
var t = Triple("a" + "1", "b" + "2", "c" + "3");
collectGarbage();
assert(t.a == "a1");
assert(t.b == "b2");
assert(t.c == "c3");

// Nested record constructor — inner record allocates while outer fields on stack
var nested = Pair(Pair("x" + "y", "z" + "w"), "after" + "inner");
collectGarbage();
assert(nested.first.first == "xy");
assert(nested.first.second == "zw");
assert(nested.second == "afterinner");

// Record with array field constructed inline
var withArr = Pair(newArray(), "str" + "val");
arrayPush(withArr.first, "elem");
collectGarbage();
assert(arrayGet(withArr.first, 0) == "elem");
assert(withArr.second == "strval");

// =========================================================================
