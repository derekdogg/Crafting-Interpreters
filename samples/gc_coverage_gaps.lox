  x = "c296"; x = "c297"; x = "c298"; x = "c299";
  return x;
}
var lastConst = manyConstants();
assert(lastConst == "c299");
collectGarbage();

// =========================================================================
// TEST 7: Concat result matching an existing interned string (dedup + GC)
// If the concat result deduplicates to an existing interned string,
// the intern table must keep the original alive.
// =========================================================================

var original = "foobar";
collectGarbage();
// This concat produces "foobar" — should deduplicate to `original`
var concat = "foo" + "bar";
assert(concat == original);
collectGarbage();
// Both must survive
assert(original == "foobar");
assert(concat == "foobar");

// Stress: interning dedup in a loop
var target = "xy";
for (var i = 0; i < 20; i = i + 1) {
  var dup = "x" + "y";
  assert(dup == target);
  collectGarbage();
}
assert(target == "xy");

// =========================================================================
// TEST 8: Mixed-type upvalues all closed at once on scope exit
// When a scope exits with multiple locals of different heap types,
// OP_CLOSE_UPVALUE is called for each. GC must trace all of them.
// =========================================================================

fun closeMixed() {
  var s = "stringval";
  var arr = newArray();
  arrayPush(arr, "elem1");
  arrayPush(arr, "elem2");
  var d = dictNew();
  dictSet(d, "dk", "dv");
  var rec = Pair("rx", "ry");
  fun inner() { return s; }
  fun inner2() { return arr; }
  fun inner3() { return d; }
  fun inner4() { return rec; }

  // All four locals will be closed when closeMixed returns
  return Pair(Pair(inner, inner2), Pair(inner3, inner4));
}

var closures = closeMixed();
// All frames dead — only closed upvalues keep objects alive
collectGarbage();
collectGarbage();

var getS = closures.first.first;
var getArr2 = closures.first.second;
var getD = closures.second.first;
var getRec = closures.second.second;

assert(getS() == "stringval");
var a2 = getArr2();
assert(arrayLen(a2) == 2);
assert(arrayGet(a2, 0) == "elem1");
var d2 = getD();
assert(dictGet(d2, "dk") == "dv");
var r2 = getRec();
assert(r2.first == "rx");
assert(r2.second == "ry");

// =========================================================================
// TEST 9: Record as closed upvalue with field mutation after closing
// =========================================================================

fun closeAndMutateRecord() {
  var r = Pair("original", 0);
  fun getR() { return r; }
  fun setR(v) { r.first = v; }
  return Pair(getR, setR);
}

var accessors = closeAndMutateRecord();
collectGarbage();
var getR = accessors.first;
var setR = accessors.second;
assert(getR().first == "original");
setR("mutated" + "value");
collectGarbage();
assert(getR().first == "mutatedvalue");

// =========================================================================
// TEST 10: Passing records as arguments while other args allocate
// =========================================================================

record Data(amount);
var dataTest = Data(1);
assert(dataTest.amount == 1);

// rec is on stack while "prefix" + ":" allocates
var d10 = Data(42);
fun fmt(r, prefix) { return prefix + str(r.amount); }
var out = fmt(d10, "num" + ":");
assert(out == "num:42");

// Multiple records as args with interleaved allocations
fun add3(a, b, c) { return a.amount + b.amount + c.amount; }
var sum = add3(Data(10), Data(20), Data(30));
assert(sum == 60);
collectGarbage();

print "gc_coverage_gaps: all passed";
