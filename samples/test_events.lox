// Event-driven callback test
// Run this with the Event Test form.
// Press keys, click the canvas, and click the buttons.

var running = true;
var keyCount = 0;
var clickCount = 0;

// --- Canvas / form-level events (no control name = default) ---

onKeyPressed(fun(key) {
  keyCount = keyCount + 1;
  print "KEY DOWN: " + key + " (total: " + str(keyCount) + ")";
  if (key == "escape") {
    running = false;
  }
});

onKeyReleased(fun(key) {
  print "KEY UP:   " + key;
});

onMouseDown(fun(btn, x, y) {
  clickCount = clickCount + 1;
  print "CANVAS MOUSE DOWN: btn=" + str(btn) + " at (" + str(x) + "," + str(y) + ")";
});

onMouseMove(fun(x, y) {
  // Uncomment to see move events:
  // print "MOUSE MOVE: at (" + str(x) + "," + str(y) + ")";
});

onKeyHeld(fun(key) {
  if (key == "left")  print "moving left";
  if (key == "right") print "moving right";
  if (key == "up")    print "moving up";
  if (key == "down")  print "moving down";
});

onMouseUp(fun(btn, x, y) {
  print "CANVAS MOUSE UP:   btn=" + str(btn) + " at (" + str(x) + "," + str(y) + ")";
});

// --- Named-target events (control name as first argument) ---

onClick("button1", fun() {
  print "[BUTTON1] clicked!";
});

onClick("button2", fun() {
  print "[BUTTON2] clicked!";
});

// You can also hook mouse events on specific controls:
onMouseDown("panel1", fun(btn, x, y) {
  print "[PANEL1] mouse down: btn=" + str(btn) + " at (" + str(x) + "," + str(y) + ")";
});

print "Event test started. Press keys, click canvas or buttons. ESC to quit.";

while (running) {
  processEvents();
}

print "Done! Keys pressed: " + str(keyCount) + ", Clicks: " + str(clickCount);
