// ============================================================
// compound_assign_field.lox — Tests for += -= *= /= on record fields
// ============================================================

record Point(x, y);

// --- Test 1: += on a field ---
var p = Point(10, 20);
p.x += 5;
print p.x; // expect: 15

// --- Test 2: -= on a field ---
p.y -= 8;
print p.y; // expect: 12

// --- Test 3: *= on a field ---
p.x *= 3;
print p.x; // expect: 45

// --- Test 4: /= on a field ---
p.x /= 9;
print p.x; // expect: 5

// --- Test 5: Compound assign doesn't affect other fields ---
var q = Point(100, 200);
q.x += 1;
print q.x; // expect: 101
print q.y; // expect: 200

// --- Test 6: String concatenation on a field ---
record Named(name, value);
var obj = Named("hello", 42);
obj.name += " world";
print obj.name; // expect: hello world

// --- Test 7: Chained field compound assignment ---
var r = Point(1, 1);
r.x += 2;
r.x *= 3;
r.x -= 1;
print r.x; // expect: 8

// --- Test 8: Compound assign in a loop ---
var acc = Point(0, 0);
var i = 0;
while (i < 10) {
  acc.x += i;
  i += 1;
}
print acc.x; // expect: 45

// --- Test 9: Compound assign with expression RHS ---
var s = Point(10, 5);
s.x += s.y * 2;
print s.x; // expect: 20

print "All field compound assignment tests passed."; // expect: All field compound assignment tests passed.
