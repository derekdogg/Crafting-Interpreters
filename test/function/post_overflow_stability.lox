// Post-overflow VM stability test.
// Verifies: after a stack overflow error, the VM can be re-invoked cleanly.
// This is a companion to boundary_overflow.lox — that file tests the error fires;
// this file tests the VM survives.
//
// NOTE: Each InterpretResult call is a fresh VM invocation in the test runner,
// so this tests that the VM initialization/teardown cycle handles the overflow
// case cleanly. The harness runs each .lox file independently.
//
// What we CAN test here: that moderate-depth recursion works correctly,
// proving the VM infrastructure (frame array, stack, globals) is not
// permanently corrupted by being part of the same test suite run.

fun recurse(n) {
  if (n == 0) return "ok";
  return recurse(n - 1);
}

fun sanity() {
  return 42;
}

// Normal depth works
print recurse(200); // expect: ok

// Max depth works
print recurse(254); // expect: ok

// VM is functional after max-depth
print sanity(); // expect: 42

// Multiple max-depth calls in sequence
print recurse(254); // expect: ok
print recurse(254); // expect: ok
print sanity(); // expect: 42
