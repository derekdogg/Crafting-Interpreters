// Deep mutual recursion (isEven/isOdd pattern) to depth 200.
// Verifies: alternating frame pushes between two functions,
//           correct return values propagating through interleaved frames.

fun isEven(n) {
  if (n == 0) return true;
  return isOdd(n - 1);
}

fun isOdd(n) {
  if (n == 0) return false;
  return isEven(n - 1);
}

print isEven(200); // expect: true
print isOdd(200);  // expect: false
print isEven(199); // expect: false
print isOdd(199);  // expect: true
