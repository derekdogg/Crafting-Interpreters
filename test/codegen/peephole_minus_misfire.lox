// Reproduces the OP_GET_LOCAL_CONST_SUBTRACT peephole misfire.
//
// The peephole in `binary()` for TOKEN_MINUS looks back 3 bytes and assumes
// code[count-3] is an opcode in [OP_GET_LOCAL_0 .. OP_GET_LOCAL_7] (49..56).
// But that byte can be an OPERAND of an earlier OP_GET_GLOBAL (=18) whose
// constant index just happens to fall in 49..56.
//
// When that happens the peephole strips 3 bytes, leaving the OP_GET_GLOBAL
// opcode orphaned without its operand, and writes OP_GET_LOCAL_CONST_SUBTRACT
// after it. At dispatch OP_GET_GLOBAL reads the NEXT byte (=66, which is
// OP_GET_LOCAL_CONST_SUBTRACT's opcode value) as its constant index. If
// constants[66] is a number rather than a string, you get an EAccessViolation
// in ObjStringToAnsiString.
//
// Trigger recipe:
//   1) Be inside a function chunk (so the function's *own* constants pool
//      is what matters).
//   2) Push number literals into that chunk until the identifier-string
//      constant for some global lands at index in [49..56].
//   3) Write `THAT_GLOBAL - <numeric literal>` (any literal already in pool).

var TARGET = 100;

fun trigger() {
  // 51 distinct numeric literals (0..50). Each `s = s + N;` adds N to the
  // local function chunk's constants pool. After this block the pool has
  // exactly indices 0..50 used by numbers (locals don't consume constants).
  var s = 0;
  s = s + 1;  s = s + 2;  s = s + 3;  s = s + 4;  s = s + 5;
  s = s + 6;  s = s + 7;  s = s + 8;  s = s + 9;  s = s + 10;
  s = s + 11; s = s + 12; s = s + 13; s = s + 14; s = s + 15;
  s = s + 16; s = s + 17; s = s + 18; s = s + 19; s = s + 20;
  s = s + 21; s = s + 22; s = s + 23; s = s + 24; s = s + 25;
  s = s + 26; s = s + 27; s = s + 28; s = s + 29; s = s + 30;
  s = s + 31; s = s + 32; s = s + 33; s = s + 34; s = s + 35;
  s = s + 36; s = s + 37; s = s + 38; s = s + 39; s = s + 40;
  s = s + 41; s = s + 42; s = s + 43; s = s + 44; s = s + 45;
  s = s + 46; s = s + 47; s = s + 48; s = s + 49; s = s + 50;

  // Next constant added is the identifier string "TARGET" -- it lands at
  // index 51, which equals OP_GET_LOCAL_2 (49 + 2). The next byte is
  // OP_CONSTANT(=0), idx_of_28 -- so the peephole's pattern check sees:
  //   code[count-3] = 51   (looks like OP_GET_LOCAL_2)
  //   code[count-2] = 0    (OP_CONSTANT)
  //   code[count-1] = 28   (constant index of "28")
  // and mis-fuses, leaving OP_GET_GLOBAL with no operand. Without the fix,
  // this should AV in OP_GET_GLOBAL with constants[66] = 28.0.
  return TARGET - 28;
}

// Expected: 100 - 28 == 72
print trigger();
// expect: 72
