// substr() extracts a substring: substr(string, start, length)
// start is 0-based

print substr("hello", 0, 5); // expect: hello
print substr("hello", 1, 3); // expect: ell
print substr("hello", 0, 1); // expect: h
print substr("hello", 4, 1); // expect: o

// Clamps length to remaining characters
print substr("hello", 3, 100); // expect: lo

// Edge cases
print substr("hello", 0, 0); // expect: 
print substr("a", 0, 1); // expect: a
