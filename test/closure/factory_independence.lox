// A factory function called multiple times. Each call creates an independent
// closure with its own closed-over state.

fun makeAdder(base) {
  fun add(n) {
    base = base + n;
    return base;
  }
  return add;
}

var add5 = makeAdder(5);
var add100 = makeAdder(100);

print add5(1);   // expect: 6
print add5(2);   // expect: 8
print add100(1); // expect: 101
print add5(10);  // expect: 18
print add100(50); // expect: 151
