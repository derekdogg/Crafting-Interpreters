// ============================================================
// inject_rtti_discovery.lox — Test loxObjects / loxObjectInfo
// ============================================================
// Setup: Delphi injects TCustomer as 'cust' and TAddress as 'addr2'.
//
// Tests:
//   - loxObjects() returns injected instance names
//   - loxObjectInfo() returns properties and methods for an injected object
//   - loxClasses() still works (returns attributed class names)

// -- Discovery: what objects are available? --
var objects = loxObjects();
print objects;
// expect: [addr2, cust]

// -- Introspect an injected object --
var info = loxObjectInfo("cust");
print info["class"];
// expect: TCustomer

print info["properties"];
// expect: [Name, Age, Balance, Active, Address, Tier, Flags, Tags]

print info["methods"];
// expect: [Greet, AddBalance, SetInfo, Describe, SetAddress, GetTags, SetTags]

// -- Class-level introspection still works --
var classes = loxClasses();
print classes;
// expect: [Address, Customer]

// -- Use the discovered object --
print cust.Name;
// expect: Alice

print cust.Greet();
// expect: Hello, Alice!
