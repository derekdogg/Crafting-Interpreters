// ============================================================
// inject_rtti_err_arg_dict.lox — Dict arg to Delphi method
// ============================================================
// Setup: Delphi injects a TCustomer as global 'cust'.
//
// What this tests:
//   - Passing a Lox dictionary where a Delphi string is expected
//   - Dictionaries never marshal to Delphi parameters, so overload
//     selection rejects the call with a runtime error
var d = [:];
d.Set("key", "value");
cust.SetInfo(d, 10); // expect runtime error: No overload of 'SetInfo' matches the given 2 argument(s).
