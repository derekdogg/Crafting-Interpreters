// ============================================================
// inject_rtti_err_arg_dict.lox — Dict arg to Delphi method
// ============================================================
// Setup: Delphi injects a TCustomer as global 'cust'.
//
// What this tests:
//   - Passing a Lox dictionary where a Delphi string is expected
//   - LoxValueToDelphi should detect the unmarshalable type and raise
//     a runtime error before the RTTI invoke proceeds
var d = [:];
d.Set("key", "value");
cust.SetInfo(d, 10); // expect runtime error: Cannot marshal Lox okDictionary to Delphi.
