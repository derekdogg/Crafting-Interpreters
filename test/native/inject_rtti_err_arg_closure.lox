// ============================================================
// inject_rtti_err_arg_closure.lox — Closure arg to Delphi method
// ============================================================
// Setup: Delphi injects a TCustomer as global 'cust'.
//
// What this tests:
//   - Passing a Lox function/closure where a Delphi string is expected
//   - Closures only match tkMethod (event/callback) parameters, so
//     overload selection rejects the call with a runtime error
fun dummy() { return "hi"; }
cust.SetInfo(dummy, 10); // expect runtime error: No overload of 'SetInfo' matches the given 2 argument(s).
