// ============================================================
// inject_rtti_err_set_closure.lox — Assign Lox closure to property
// ============================================================
// Setup: Delphi injects a TCustomer as global 'cust'.
//
// What this tests:
//   - Assigning a Lox function/closure to a Delphi string property
//   - Closures only bind to tkMethod (event/callback) targets, so the
//     assignment raises a runtime error before SetValue proceeds
fun dummy() { return "hi"; }
cust.Name = dummy; // expect runtime error: A function can only be passed where a Delphi event/callback is expected.
