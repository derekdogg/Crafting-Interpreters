// ============================================================
// inject_rtti_err_wrong_arity.lox — Wrong argument count
// ============================================================
// Setup: Delphi injects a TCustomer as global 'cust'.
//
// What this tests:
//   - Calling SetInfo with 1 arg when it expects 2 (string, integer)
//   - RTTI overload resolution matches by name, then arity + argument
//     types — no overload fits, so a descriptive error is raised
print cust.Name; // expect: Alice
cust.SetInfo("Bob"); // expect runtime error: No overload of 'SetInfo' matches the given 1 argument(s).
