// abs() returns the absolute value of a number

print abs(5); // expect: 5
print abs(-5); // expect: 5
print abs(0); // expect: 0
print abs(-3.14); // expect: 3.14
print abs(3.14); // expect: 3.14

// Edge cases
print abs(-0); // expect: 0
print abs(0.001); // expect: 0.001
print abs(-0.001); // expect: 0.001
