{
  var x = 1;
  {
    var x = 2;
    {
      var x = 3;
      {
        var x = 4;
        {
          var x = 5;
          {
            var x = 6;
            {
              var x = 7;
              {
                var x = 8;
                {
                  var x = 9;
                  {
                    var x = 10;
                    {
                      var x = 11;
                      {
                        var x = 12;
                        {
                          var x = 13;
                          {
                            var x = 14;
                            {
                              var x = 15;
                              {
                                var x = 16;
                                {
                                  var x = 17;
                                  {
                                    var x = 18;
                                    {
                                      var x = 19;
                                      {
                                        var x = 20;
                                        result = x;
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
