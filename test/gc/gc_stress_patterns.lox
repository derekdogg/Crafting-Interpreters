// GC Stress Patterns — exercises all major GC-sensitive allocation patterns.
// Each section forces collection repeatedly during the stress operation.

record Node(value, next);
record Tree(left, right, data);
record Wrapper(ref);

// =========================================================================
// PATTERN 1: Allocation Storm
// Rapidly create lots of short-lived objects, discard most immediately.
// =========================================================================

for (var i = 0; i < 200; i = i + 1) {
  // Each iteration creates a temporary string, array, and dict — all discarded
  var tmp = "storm" + str(i) + "x";
  var arr = newArray();
  arrayPush(arr, tmp);
  arrayPush(arr, newArray());
  var d = dictNew();
  dictSet(d, "k", tmp);
  if (i % 20 == 0) collectGarbage();
}
collectGarbage();
print "pattern 1 (allocation storm): passed";

// =========================================================================
// PATTERN 2: Long-Lived + Short-Lived Mix
// Keep anchors alive while churning many temporaries around them.
// =========================================================================

var anchor1 = newArray();
var anchor2 = dictNew();
var anchor3 = Node("root", nil);

for (var i = 0; i < 150; i = i + 1) {
  // Anchor survives; temps die
  arrayPush(anchor1, "a" + str(i));
  dictSet(anchor2, "k" + str(i), i);
  // Create temps that reference the anchor (but we drop the temp)
  var temp = Node(anchor1, nil);
  var tempArr = newArray();
  arrayPush(tempArr, anchor2);
  if (i % 10 == 0) collectGarbage();
}

collectGarbage();
assert(arrayLen(anchor1) == 150);
assert(dictGet(anchor2, "k0") == 0);
assert(dictGet(anchor2, "k149") == 149);
assert(anchor3.value == "root");
print "pattern 2 (long+short lived mix): passed";

// =========================================================================
// PATTERN 3: Pointer Graphs — linked list construction and traversal
// =========================================================================

// Build a linked list of 500 nodes
var head = nil;
for (var i = 0; i < 500; i = i + 1) {
  head = Node(i, head);
  if (i % 50 == 0) collectGarbage();
}

// Traverse and verify
var current = head;
var count = 0;
while (current != nil) {
  count = count + 1;
  current = current.next;
}
assert(count == 500);
assert(head.value == 499);

// Walk halfway, GC, continue
current = head;
for (var i = 0; i < 250; i = i + 1) current = current.next;
collectGarbage();
assert(current.value == 249);

// Drop the list
head = nil;
current = nil;
collectGarbage();
print "pattern 3 (linked list pointer graph): passed";

// =========================================================================
// PATTERN 4: Cycles — create circular references, then drop all roots
// =========================================================================

// Circular linked list
fun buildCycle(size) {
  var first = Node("cycle0", nil);
  var prev = first;
  for (var i = 1; i < size; i = i + 1) {
    var n = Node("cycle" + str(i), nil);
    prev.next = n;
    prev = n;
    if (i % 20 == 0) collectGarbage();
  }
  // Close the cycle
  prev.next = first;
  return first;
}

var cycle = buildCycle(100);
// Verify cycle: walk 200 steps (wraps around)
var walk = cycle;
for (var i = 0; i < 200; i = i + 1) walk = walk.next;
assert(walk.value == "cycle0"); // back to start after 100 * 2
collectGarbage();

// Drop the cycle — all 100 nodes become garbage
cycle = nil;
walk = nil;
collectGarbage();
collectGarbage();

// Dict-based cycle: A -> B -> A
var dictA = dictNew();
var dictB = dictNew();
dictSet(dictA, "partner", dictB);
dictSet(dictB, "partner", dictA);
dictSet(dictA, "name", "A");
dictSet(dictB, "name", "B");
collectGarbage();
assert(dictGet(dictGet(dictGet(dictA, "partner"), "partner"), "name") == "A");
// Drop both
dictA = nil;
dictB = nil;
collectGarbage();
print "pattern 4 (cycles): passed";

// =========================================================================
// PATTERN 5: Mutation — change references during execution
// =========================================================================

var mutArr = newArray();
for (var i = 0; i < 50; i = i + 1) arrayPush(mutArr, Node(i, nil));

// Mutate: rewire each node's next to point to the following node
for (var i = 0; i < 49; i = i + 1) {
  var curr2 = arrayGet(mutArr, i);
  var nxt = arrayGet(mutArr, i + 1);
  curr2.next = nxt;
  // Replace array entry with new object (old one survives via .next chain)
  if (i % 10 == 0) {
    collectGarbage();
  }
}

// Verify chain is intact through the first node
var chainNode = arrayGet(mutArr, 0);
for (var i = 0; i < 49; i = i + 1) {
  assert(chainNode.value == i);
  chainNode = chainNode.next;
}
assert(chainNode.value == 49);
collectGarbage();

// Overwrite half the array — orphaning nodes only reachable via chain
for (var i = 0; i < 25; i = i + 1) {
  arraySet(mutArr, i, nil);
  if (i % 5 == 0) collectGarbage();
}
// Chain still reachable via arrayGet(mutArr, 25).value ... but the head is gone
// The head's chain is only reachable if something still points to it — it shouldn't be
collectGarbage();
// Node at index 25 should still be intact
var midNode = arrayGet(mutArr, 25);
assert(midNode.value == 25);
print "pattern 5 (mutation): passed";

// =========================================================================
// PATTERN 6: Deep Chains — very deep object hierarchy
// =========================================================================

// Build a chain 2000 levels deep
var deep = nil;
for (var i = 0; i < 2000; i = i + 1) {
  deep = Wrapper(deep);
  if (i % 200 == 0) collectGarbage();
}
collectGarbage();

// Verify depth by unwinding
var depth = 0;
var unwinding = deep;
while (unwinding != nil) {
  depth = depth + 1;
  unwinding = unwinding.ref;
}
assert(depth == 2000);

// Drop it all
deep = nil;
unwinding = nil;
collectGarbage();
print "pattern 6 (deep chains 2000 levels): passed";

// =========================================================================
// PATTERN 7: Container Thrash — repeated insert/delete forcing resize
// =========================================================================

// Dict thrash: insert many, remove many, repeat
var thrashDict = dictNew();
for (var round = 0; round < 5; round = round + 1) {
  // Insert 80 entries
  for (var i = 0; i < 80; i = i + 1) {
    dictSet(thrashDict, "r" + str(round) + "k" + str(i), i * round);
  }
  collectGarbage();
  // Remove 60 of them
  for (var i = 0; i < 60; i = i + 1) {
    dictDelete(thrashDict, "r" + str(round) + "k" + str(i));
  }
  collectGarbage();
}
// Should have 5 rounds * 20 remaining = 100 entries
// Exhaustively verify every key: deleted ones absent, survivors have correct value
var thrashSurvivors = 0;
for (var round = 0; round < 5; round = round + 1) {
  for (var i = 0; i < 60; i = i + 1) {
    assert(dictHas(thrashDict, "r" + str(round) + "k" + str(i)) == false);
  }
  for (var i = 60; i < 80; i = i + 1) {
    var key = "r" + str(round) + "k" + str(i);
    assert(dictHas(thrashDict, key) == true);
    assert(dictGet(thrashDict, key) == i * round);
    thrashSurvivors = thrashSurvivors + 1;
  }
}
assert(thrashSurvivors == 100);

// Array thrash: push many, pop many
var thrashArr = newArray();
for (var round = 0; round < 10; round = round + 1) {
  for (var i = 0; i < 50; i = i + 1) {
    arrayPush(thrashArr, "item" + str(round) + "_" + str(i));
  }
  for (var i = 0; i < 40; i = i + 1) {
    arrayPop(thrashArr);
  }
  if (round % 3 == 0) collectGarbage();
}
collectGarbage();
// 10 rounds * 10 remaining per round = 100 elements
assert(arrayLen(thrashArr) == 100);
print "pattern 7 (container thrash): passed";

// =========================================================================
// PATTERN 8: Random Lifetimes — unpredictable object death patterns
// =========================================================================

// Use an array as a "slot pool" — randomly overwrite slots
var slots = newArray();
for (var i = 0; i < 40; i = i + 1) arrayPush(slots, nil);

for (var i = 0; i < 300; i = i + 1) {
  // Pseudo-random slot selection (deterministic for reproducibility)
  var slot = (i * 7 + 13) % 40;
  // Create a new object with varying complexity
  if (i % 3 == 0) {
    arraySet(slots, slot, Node("n" + str(i), arrayGet(slots, (slot + 1) % 40)));
  } else if (i % 3 == 1) {
    var tmpArr2 = newArray();
    arrayPush(tmpArr2, str(i));
    arrayPush(tmpArr2, arrayGet(slots, (slot + 5) % 40));
    arraySet(slots, slot, tmpArr2);
  } else {
    arraySet(slots, slot, "s" + str(i) + "end");
  }
  if (i % 25 == 0) collectGarbage();
}
collectGarbage();
// Verify slots are still accessible (no corruption)
for (var i = 0; i < 40; i = i + 1) {
  var s = arrayGet(slots, i); // just accessing shouldn't crash
}
print "pattern 8 (random lifetimes): passed";

// =========================================================================
// PATTERN 9: Closure Capture — objects reachable only via environments
// =========================================================================

// Build an array of closures, each capturing unique objects
var closureArr = newArray();
for (var i = 0; i < 50; i = i + 1) {
  // Each iteration creates a new scope with captured vars
  fun makeCapture(idx) {
    var captured = newArray();
    arrayPush(captured, "cap" + str(idx));
    var capturedDict = dictNew();
    dictSet(capturedDict, "id", idx);
    fun accessor() {
      return Node(arrayGet(captured, 0), capturedDict);
    }
    return accessor;
  }
  arrayPush(closureArr, makeCapture(i));
  if (i % 10 == 0) collectGarbage();
}

collectGarbage();
collectGarbage();

// Verify all 50 closures still work
for (var i = 0; i < 50; i = i + 1) {
  var fn = arrayGet(closureArr, i);
  var result2 = fn();
  assert(result2.value == "cap" + str(i));
  assert(dictGet(result2.next, "id") == i);
}

// Drop half the closures — their captured objects become garbage
for (var i = 0; i < 25; i = i + 1) {
  arraySet(closureArr, i, nil);
}
collectGarbage();

// Remaining half still works
for (var i = 25; i < 50; i = i + 1) {
  var fn2 = arrayGet(closureArr, i);
  var res2 = fn2();
  assert(res2.value == "cap" + str(i));
}
print "pattern 9 (closure capture): passed";

// =========================================================================
// PATTERN 10: Repeated Full GC During All Patterns Combined
// =========================================================================

// Build a complex live set, then hammer GC while mutating it
var liveList = nil;
var liveArr2 = newArray();
var liveDict2 = dictNew();

for (var i = 0; i < 100; i = i + 1) {
  // Grow linked list
  liveList = Node("live" + str(i), liveList);
  // Grow array with references to list nodes
  arrayPush(liveArr2, liveList);
  // Grow dict
  dictSet(liveDict2, "k" + str(i), liveList);
  
  // Create garbage (short-lived temps)
  var garbage1 = newArray();
  arrayPush(garbage1, "g" + str(i));
  var garbage2 = dictNew();
  dictSet(garbage2, "gk", garbage1);
  var garbage3 = Node(garbage2, nil);
  
  // Force GC every iteration — maximum stress
  collectGarbage();
}

// Verify everything survived
assert(liveList.value == "live99");
assert(arrayLen(liveArr2) == 100);
var node50 = arrayGet(liveArr2, 50);
assert(node50.value == "live50");
assert(dictGet(liveDict2, "k0").value == "live0");
assert(dictGet(liveDict2, "k99").value == "live99");

// Final double-collect
collectGarbage();
collectGarbage();

// Verify integrity after final collection
var walkList = liveList;
var listLen = 0;
while (walkList != nil) {
  listLen = listLen + 1;
  walkList = walkList.next;
}
assert(listLen == 100);

print "pattern 10 (combined stress with GC every iteration): passed";

// =========================================================================
// PATTERN 11: Shared-object explosion — many references to same object
// 1000 array slots + dict entries all pointing to one record.
// GC must not double-mark, corrupt, or prematurely free the shared target.
// =========================================================================

var shared = Node("shared_target", nil);
var refArr = newArray();
var refDict = dictNew();

for (var i = 0; i < 1000; i = i + 1) {
  arrayPush(refArr, shared);
  dictSet(refDict, "ref" + str(i), shared);
  if (i % 100 == 0) collectGarbage();
}

collectGarbage();
collectGarbage();

// Verify the shared object is still intact through all references
assert(arrayGet(refArr, 0).value == "shared_target");
assert(arrayGet(refArr, 500).value == "shared_target");
assert(arrayGet(refArr, 999).value == "shared_target");
assert(dictGet(refDict, "ref0").value == "shared_target");
assert(dictGet(refDict, "ref999").value == "shared_target");

// Mutate the shared object — all references should see the change
shared.value = "mutated";
assert(arrayGet(refArr, 0).value == "mutated");
assert(dictGet(refDict, "ref500").value == "mutated");

// Drop most references but keep one — object must survive
refArr = nil;
refDict = nil;
collectGarbage();
assert(shared.value == "mutated");

// Now build a second shared object embedded in closures
var shared2 = newArray();
arrayPush(shared2, "payload");
var closureFans = newArray();
for (var i = 0; i < 100; i = i + 1) {
  fun capture(s) {
    fun get() { return s; }
    return get;
  }
  arrayPush(closureFans, capture(shared2));
  if (i % 20 == 0) collectGarbage();
}
collectGarbage();

// All 100 closures return the same array
for (var i = 0; i < 100; i = i + 1) {
  var fn3 = arrayGet(closureFans, i);
  var got = fn3();
  assert(arrayGet(got, 0) == "payload");
}
print "pattern 11 (shared-object explosion): passed";

// =========================================================================
// PATTERN 12: Long-running sustained pressure — no rest phases
// 5000 iterations of mixed allocation with zero explicit collectGarbage()
// calls. Relies entirely on the GC threshold trigger (and DEBUG_STRESS_GC
// firing on every growing allocation).
// =========================================================================

var sustainedArr = newArray();
var sustainedList = nil;

for (var i = 0; i < 5000; i = i + 1) {
  // Create short-lived garbage
  var tmp2 = "s" + str(i) + "e";
  var tmpA = newArray();
  arrayPush(tmpA, tmp2);

  // Occasionally anchor something long-lived
  if (i % 50 == 0) {
    sustainedList = Node(i, sustainedList);
    arrayPush(sustainedArr, sustainedList);
  }
}

// Verify long-lived structures survived thousands of GC cycles
assert(arrayLen(sustainedArr) == 100); // 5000 / 50
var sNode = arrayGet(sustainedArr, 0);
assert(sNode.value == 0);
sNode = arrayGet(sustainedArr, 99);
assert(sNode.value == 4950);

// Walk the list to verify structural integrity
var sWalk = sustainedList;
var sCount = 0;
while (sWalk != nil) {
  sCount = sCount + 1;
  sWalk = sWalk.next;
}
assert(sCount == 100);

collectGarbage();
print "pattern 12 (sustained pressure 5000 iterations): passed";

// =========================================================================
// PATTERN 13: Verify unreachable cycles are actually reclaimed
// Uses bytesAllocated() to prove memory goes DOWN after dropping a cycle.
// =========================================================================

// Build a fat cycle — each node has a string field to make it heavy
fun buildFatCycle(size) {
  var first = Node("fat_cycle_node_0_padding_string", nil);
  var prev2 = first;
  for (var i = 1; i < size; i = i + 1) {
    var n2 = Node("fat_cycle_node_" + str(i) + "_padding_string", nil);
    prev2.next = n2;
    prev2 = n2;
  }
  prev2.next = first;
  return first;
}

// Force a clean baseline
collectGarbage();
var baseline = bytesAllocated();

// Create the cycle
var fatCycle = buildFatCycle(200);
collectGarbage();
var withCycle = bytesAllocated();
assert(withCycle > baseline); // cycle is using memory

// Drop all references to the cycle
fatCycle = nil;
collectGarbage();
var afterDrop = bytesAllocated();

// Memory should have decreased — the cycle was reclaimed
assert(afterDrop < withCycle);

// Repeat with dict-based cycle
collectGarbage();
var base2 = bytesAllocated();

var cA = dictNew();
var cB = dictNew();
var cC = dictNew();
dictSet(cA, "next", cB);
dictSet(cB, "next", cC);
dictSet(cC, "next", cA);
// Add bulk data
for (var i = 0; i < 50; i = i + 1) {
  dictSet(cA, "data" + str(i), "value" + str(i));
  dictSet(cB, "data" + str(i), "value" + str(i));
  dictSet(cC, "data" + str(i), "value" + str(i));
}
collectGarbage();
var withDictCycle = bytesAllocated();
assert(withDictCycle > base2);

cA = nil;
cB = nil;
cC = nil;
collectGarbage();
var afterDictDrop = bytesAllocated();
assert(afterDictDrop < withDictCycle);

print "pattern 13 (cycle reclamation verified): passed";

// =========================================================================
// PATTERN 14: String intern table churn at scale
// Create 2000 unique strings, abandon them, GC, verify memory is reclaimed.
// This stresses TableRemoveWhite on the intern table.
// =========================================================================

// Build an array of unique strings — kept alive until we drop the array.
fun buildStrings(count2) {
  var arr = newArray();
  for (var i = 0; i < count2; i = i + 1) {
    arrayPush(arr, "churn_" + str(i) + "_end");
  }
  return arr;
}

// Warm up: grow the intern table to steady-state capacity.
var warmup = buildStrings(2000);
warmup = nil;
collectGarbage();
warmup = buildStrings(2000);
warmup = nil;
collectGarbage();

// NOW measure: hold 2000 strings alive, measure, then drop and collect.
var held = buildStrings(2000);
collectGarbage();
var withStrings = bytesAllocated();

held = nil;
collectGarbage();
var afterDrop = bytesAllocated();

assert(afterDrop < withStrings);
var freed = withStrings - afterDrop;
assert(freed > 10000);

// Stress: repeated build/drop cycles — verify no unbounded growth
var stableBase = afterDrop;
for (var wave = 0; wave < 5; wave = wave + 1) {
  var batch = buildStrings(500);
  batch = nil;
  collectGarbage();
}
var afterWaves = bytesAllocated();
assert(afterWaves - stableBase < 50000);

// Verify that strings we DO keep are still interned correctly
var kept1 = "keeper_string";
var kept2 = "keeper" + "_" + "string";
assert(kept1 == kept2); // interning dedup
collectGarbage();
assert(kept1 == "keeper_string"); // survived

print "pattern 14 (intern table churn 2000+ strings): passed";

// =========================================================================
// PATTERN 15: Stack realloc with open upvalues
// Forces the VM stack to grow past START_CAPACITY (256 slots) while open
// upvalues point into the stack buffer. If the rebase fix is missing,
// the upvalue location pointer becomes dangling after ReallocMem moves
// the buffer, and reading the upvalue returns garbage.
// =========================================================================

fun stackReallocTest() {
  // Outer function captures a variable
  var captured = "before_realloc";

  fun inner() {
    // This function captures `captured` via an open upvalue.
    // To trigger the stack realloc, we need to push the stack past 256 slots.
    // We do this by calling a "stack filler" that declares many locals.
    // The upvalue for `captured` still points into the outer frame's slot.

    fun fillStack() {
      // 255 locals (max per function) — each is a stack slot. With slot 0
      // reserved for the function object, this frame alone needs 256 slots.
      // Combined with enclosing frames, it guarantees pushStack() must grow
      // past START_CAPACITY (256), triggering the ReallocMem code path.
      var a0=0; var a1=1; var a2=2; var a3=3; var a4=4; var a5=5; var a6=6; var a7=7;
      var a8=8; var a9=9; var a10=10; var a11=11; var a12=12; var a13=13; var a14=14; var a15=15;
      var a16=16; var a17=17; var a18=18; var a19=19; var a20=20; var a21=21; var a22=22; var a23=23;
      var a24=24; var a25=25; var a26=26; var a27=27; var a28=28; var a29=29; var a30=30; var a31=31;
      var a32=32; var a33=33; var a34=34; var a35=35; var a36=36; var a37=37; var a38=38; var a39=39;
      var a40=40; var a41=41; var a42=42; var a43=43; var a44=44; var a45=45; var a46=46; var a47=47;
      var a48=48; var a49=49; var a50=50; var a51=51; var a52=52; var a53=53; var a54=54; var a55=55;
      var a56=56; var a57=57; var a58=58; var a59=59; var a60=60; var a61=61; var a62=62; var a63=63;
      var a64=64; var a65=65; var a66=66; var a67=67; var a68=68; var a69=69; var a70=70; var a71=71;
      var a72=72; var a73=73; var a74=74; var a75=75; var a76=76; var a77=77; var a78=78; var a79=79;
      var a80=80; var a81=81; var a82=82; var a83=83; var a84=84; var a85=85; var a86=86; var a87=87;
      var a88=88; var a89=89; var a90=90; var a91=91; var a92=92; var a93=93; var a94=94; var a95=95;
      var a96=96; var a97=97; var a98=98; var a99=99; var a100=100; var a101=101; var a102=102; var a103=103;
      var a104=104; var a105=105; var a106=106; var a107=107; var a108=108; var a109=109; var a110=110; var a111=111;
      var a112=112; var a113=113; var a114=114; var a115=115; var a116=116; var a117=117; var a118=118; var a119=119;
      var a120=120; var a121=121; var a122=122; var a123=123; var a124=124; var a125=125; var a126=126; var a127=127;
      var a128=128; var a129=129; var a130=130; var a131=131; var a132=132; var a133=133; var a134=134; var a135=135;
      var a136=136; var a137=137; var a138=138; var a139=139; var a140=140; var a141=141; var a142=142; var a143=143;
      var a144=144; var a145=145; var a146=146; var a147=147; var a148=148; var a149=149; var a150=150; var a151=151;
      var a152=152; var a153=153; var a154=154; var a155=155; var a156=156; var a157=157; var a158=158; var a159=159;
      var a160=160; var a161=161; var a162=162; var a163=163; var a164=164; var a165=165; var a166=166; var a167=167;
      var a168=168; var a169=169; var a170=170; var a171=171; var a172=172; var a173=173; var a174=174; var a175=175;
      var a176=176; var a177=177; var a178=178; var a179=179; var a180=180; var a181=181; var a182=182; var a183=183;
      var a184=184; var a185=185; var a186=186; var a187=187; var a188=188; var a189=189; var a190=190; var a191=191;
      var a192=192; var a193=193; var a194=194; var a195=195; var a196=196; var a197=197; var a198=198; var a199=199;
      var a200=200; var a201=201; var a202=202; var a203=203; var a204=204; var a205=205; var a206=206; var a207=207;
      var a208=208; var a209=209; var a210=210; var a211=211; var a212=212; var a213=213; var a214=214; var a215=215;
      var a216=216; var a217=217; var a218=218; var a219=219; var a220=220; var a221=221; var a222=222; var a223=223;
      var a224=224; var a225=225; var a226=226; var a227=227; var a228=228; var a229=229; var a230=230; var a231=231;
      var a232=232; var a233=233; var a234=234; var a235=235; var a236=236; var a237=237; var a238=238; var a239=239;
      var a240=240; var a241=241; var a242=242; var a243=243; var a244=244; var a245=245; var a246=246; var a247=247;
      var a248=248; var a249=249; var a250=250; var a251=251; var a252=252; var a253=253; var a254=254;
      // Use the last one to prevent optimization
      return a254;
    }

    // Call fillStack — this pushes the stack way past 256 slots
    var filler = fillStack();
    assert(filler == 254);

    // NOW read the captured variable via the open upvalue.
    // Without the rebase fix, `captured` points to the OLD (freed) stack buffer.
    return captured;
  }

  var result3 = inner();
  assert(result3 == "before_realloc");

  // Also test mutation through the upvalue after realloc
  fun mutator() {
    fun fillStack2() {
